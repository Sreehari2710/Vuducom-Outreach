// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         String     @default("EMPLOYEE") // ADMIN, EMPLOYEE
  
  // SMTP Settings
  senderName   String?
  smtpEmail    String?
  smtpPassword String?    // App Secret
  
  // Relations
  templates     Template[]
  campaigns     Campaign[]
  notifications Notification[]
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Template {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  campaigns Campaign[]
  
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model Campaign {
  id         String   @id @default(cuid())
  name       String   @unique
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateId String?
  contacts   Contact[]
  emails     SentEmail[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
}

model Contact {
  id         String   @id @default(cuid())
  email      String
  username   String?
  followers  Int?
  customData String?  // Store JSON mapping of {var: value}
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  createdAt  DateTime @default(now())
}

model SentEmail {
  id         String   @id @default(cuid())
  messageId  String   @unique
  recipient  String
  username   String?
  status     String   // "SENT", "FAILED", "REPLIED"
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  replies    Reply[]
  sentAt     DateTime @default(now())
}

model Reply {
  id          String    @id @default(cuid())
  sender      String
  body        String
  receivedAt  DateTime  @default(now())
  parentEmail SentEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
  emailId     String
}

model Notification {
  id         String   @id @default(cuid())
  title      String
  message    String
  type       String   @default("INFO") // INFO, SUCCESS, REPLY, ERROR
  isRead     Boolean  @default(false)
  campaignId String?
  createdAt  DateTime @default(now())
  
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
}
